---
layout: null
permalink: /search.json
sitemap: false
---
[
  {%- for post in site.posts -%}
  {%- assign pillars = post.categories | concat: post.tags | join: " " | downcase -%}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: "%B %-d, %Y" | jsonify }},
    "pillars": {{ pillars | jsonify }},
    "excerpt": {{ post.excerpt | strip_html | strip_newlines | truncatewords: 30 | jsonify }},
    "content": {{ post.content | strip_html | strip_newlines | truncatewords: 80 | jsonify }}
  }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]
